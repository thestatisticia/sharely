# ShareGEscrow on Celo — deploy contracts/ShareGEscrow.sol then paste address
NEXT_PUBLIC_ESCROW_ADDRESS=

# Supabase — Project Settings → API (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Publishable key (sb_publishable_...) or legacy anon JWT (eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key
# Server-only — sb_secret_... or legacy service_role JWT (never expose in client / git)
SUPABASE_SERVICE_ROLE_KEY=your_secret_or_service_role_key

# Optional: deployer key for npm run deploy:escrow (never commit real keys)
DEPLOYER_PRIVATE_KEY=
